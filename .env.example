# Isolated Codex build. Do not put live credentials in git.

# Provider mode. The current app ships with mock only.
UAE_PROVIDER=mock

# Future adapter posture:
# - mock: deterministic demo data
# - delayed_official: approved public/delayed sources only
# - licensed: licensed market-data vendor
UAE_MARKET_DATA_MODE=mock

# AI posture:
# - local_stub: deterministic copy from scored facts
# - structured_llm: future JSON extraction/summarization provider
UAE_AI_MODE=local_stub

# Mizan Codex agent default: Ollama Cloud through the local Ollama API.
MIZAN_PROVIDER=ollama
MIZAN_MODEL=gpt-oss:120b-cloud

# Compliance copy can be made configurable before public launch.
UAE_DISCLAIMER="Research support only. Not personalized investment advice."
